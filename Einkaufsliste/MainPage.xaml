<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Einkaufsliste.MainPage">
    
    <ScrollView>
        <Grid Padding="30,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Grid.RowDefinitions>
                <RowDefinition Height="20"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="20"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            
            
            <Button Grid.Column="0" Grid.Row="1"
            Text="+" 
            Clicked="Btn_Add_Clicked"
            BackgroundColor="#512BD4"
            FontSize="20"/>

            <ImageButton x:Name="Btn_ligth_mode_settings" Grid.Column="2" Grid.Row="1"
                 Source="light_mode_settings.png"
                 WidthRequest="40"
                 HeightRequest="40"
                 BackgroundColor="Transparent"
                 Clicked="Btn_Settings_Clicked"/>


            <ImageButton x:Name="Btn_dark_mode_settings" Grid.Column="2" Grid.Row="1"
                 Source="dark_mode_settings.png"
                 WidthRequest="40"
                 HeightRequest="40"
                 BackgroundColor="Transparent"
                 Clicked="Btn_Settings_Clicked"/>


            <ImageButton x:Name="Btn_dark_mode" Grid.Column="3" Grid.Row="1"
                   Source="dark_mode_button.png"
                   WidthRequest="40"
                   HeightRequest="40"
                   Background="Transparent"
                   Clicked="Btn_Dark_Mode_Clicked" />

            <ImageButton x:Name="Btn_light_mode" Grid.Column="3" Grid.Row="1"
                         Source="light_mode_button.png"
                         WidthRequest="40"
                         HeightRequest="40"
                         Background="Transparent"
                         Clicked="Btn_Add_Clicked_Mode_Clicked"/>

            <CollectionView x:Name="clv_groceries" Grid.Row="3" Grid.ColumnSpan="4">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                    <HorizontalStackLayout Spacing="10">
                            <CheckBox VerticalOptions="Center" CheckedChanged="CheckBox_CheckedChanged" BindingContextChanged="CheckBox_BindingContextChanged" />
                            <Label Text="{Binding}" FontSize="20" VerticalOptions="Center"/>
                        </HorizontalStackLayout>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

        </Grid>

    </ScrollView>

</ContentPage>
